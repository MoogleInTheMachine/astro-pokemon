---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';

const { name } = Astro.params;

const res = await fetch(`https://pokeapi.co/api/v2/pokemon/${name}`);

if (!res.ok) {
  return Astro.redirect('/pokedex');
}

const pokemon = await res.json();

const id = pokemon.id;
const sprite = `https://raw.githubusercontent.com/PokeAPI/sprites/master/sprites/pokemon/other/official-artwork/${id}.png`;
const dexNumber = `#${String(id).padStart(3, '0')}`;
const types: string[] = pokemon.types.map((t: any) => t.type.name);
const abilities: string[] = pokemon.abilities.map((a: any) => a.ability.name);
const stats: { name: string; value: number }[] = pokemon.stats.map((s: any) => ({
  name: s.stat.name,
  value: s.base_stat,
}));
const height = pokemon.height / 10; // decimetres -> metres
const weight = pokemon.weight / 10; // hectograms -> kg
---

<BaseLayout title={`Pokédex - ${name}`}>
  <a href="/pokedex" class="back-link">&larr; Back to Pokédex</a>

  <div class="detail">
    <div class="detail-header">
      <span class="dex-number">{dexNumber}</span>
      <h1>{name!.toUpperCase()}</h1>
    </div>

    <img src={sprite} alt={name} class="artwork" />

    <div class="types">
      {types.map((t) => (
        <span class={`type-badge type-${t}`}>{t}</span>
      ))}
    </div>

    <div class="info-grid">
      <div class="info-card">
        <h3>Height</h3>
        <p>{height} m</p>
      </div>
      <div class="info-card">
        <h3>Weight</h3>
        <p>{weight} kg</p>
      </div>
    </div>

    <section class="section">
      <h2>Abilities</h2>
      <div class="ability-list">
        {abilities.map((a) => (
          <span class="ability-badge">{a}</span>
        ))}
      </div>
    </section>

    <section class="section">
      <h2>Base Stats</h2>
      <div class="stats">
        {stats.map((s) => (
          <div class="stat-row">
            <span class="stat-name">{s.name}</span>
            <div class="stat-bar-bg">
              <div class="stat-bar" style={`width: ${Math.min((s.value / 255) * 100, 100)}%`} />
            </div>
            <span class="stat-value">{s.value}</span>
          </div>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .back-link {
    display: inline-block;
    margin-bottom: 1.5rem;
    font-weight: 500;
    color: #e63946;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .detail {
    max-width: 560px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .detail-header {
    text-align: center;
    margin-bottom: 1rem;
  }

  .dex-number {
    font-size: 1rem;
    font-weight: 700;
    color: #aaa;
  }

  h1 {
    font-size: 2.25rem;
    margin-top: 0.25rem;
  }

  .artwork {
    width: 240px;
    height: 240px;
    object-fit: contain;
  }

  .types {
    display: flex;
    gap: 0.5rem;
    margin: 1rem 0;
  }

  .type-badge {
    padding: 0.35rem 1rem;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.85rem;
    color: white;
    text-transform: capitalize;
    background: #777;
  }

  .type-normal { background: #a8a77a; }
  .type-fire { background: #ee8130; }
  .type-water { background: #6390f0; }
  .type-electric { background: #f7d02c; color: #333; }
  .type-grass { background: #7ac74c; }
  .type-ice { background: #96d9d6; color: #333; }
  .type-fighting { background: #c22e28; }
  .type-poison { background: #a33ea1; }
  .type-ground { background: #e2bf65; color: #333; }
  .type-flying { background: #a98ff3; }
  .type-psychic { background: #f95587; }
  .type-bug { background: #a6b91a; }
  .type-rock { background: #b6a136; }
  .type-ghost { background: #735797; }
  .type-dragon { background: #6f35fc; }
  .type-dark { background: #705746; }
  .type-steel { background: #b7b7ce; color: #333; }
  .type-fairy { background: #d685ad; }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    width: 100%;
    margin-bottom: 1.5rem;
  }

  .info-card {
    background: white;
    border-radius: 10px;
    padding: 1rem;
    text-align: center;
    border: 1px solid #eee;
  }

  .info-card h3 {
    font-size: 0.8rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.25rem;
  }

  .info-card p {
    font-size: 1.25rem;
    font-weight: 700;
  }

  .section {
    width: 100%;
    margin-bottom: 1.5rem;
  }

  h2 {
    font-size: 1.25rem;
    margin-bottom: 0.75rem;
  }

  .ability-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .ability-badge {
    padding: 0.4rem 0.9rem;
    background: white;
    border: 1px solid #ddd;
    border-radius: 20px;
    font-size: 0.9rem;
    text-transform: capitalize;
  }

  .stats {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .stat-row {
    display: grid;
    grid-template-columns: 140px 1fr 40px;
    align-items: center;
    gap: 0.75rem;
  }

  .stat-name {
    font-size: 0.85rem;
    text-transform: capitalize;
    color: #555;
  }

  .stat-bar-bg {
    height: 10px;
    background: #eee;
    border-radius: 5px;
    overflow: hidden;
  }

  .stat-bar {
    height: 100%;
    background: #e63946;
    border-radius: 5px;
    transition: width 0.3s;
  }

  .stat-value {
    font-weight: 700;
    font-size: 0.9rem;
    text-align: right;
  }
</style>
