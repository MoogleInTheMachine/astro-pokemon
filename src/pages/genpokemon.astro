---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Pokédex - Generate">
  <h1>Generate a Pokémon</h1>
  <p class="subtitle">Use AI to create a brand new, never-before-seen Pokémon.</p>

  <div class="gen-container">
    <button id="generate-btn" class="gen-btn">Generate</button>

    <div id="loading" class="loading">Creating your Pokémon...</div>
    <div id="error" class="error"></div>

    <div id="result" class="result">
      <div class="poke-header">
        <h2 id="poke-name"></h2>
        <span id="poke-category" class="category"></span>
      </div>

      <div id="poke-types" class="types"></div>

      <p id="poke-desc" class="description"></p>

      <div class="info-grid">
        <div class="info-card">
          <h3>Height</h3>
          <p id="poke-height"></p>
        </div>
        <div class="info-card">
          <h3>Weight</h3>
          <p id="poke-weight"></p>
        </div>
      </div>

      <div class="section">
        <h3>Abilities</h3>
        <div id="poke-abilities" class="ability-list"></div>
      </div>

      <div class="section">
        <h3>Base Stats</h3>
        <div id="poke-stats" class="stats"></div>
      </div>

      <div class="section">
        <h3>Lore</h3>
        <p id="poke-lore" class="lore-text"></p>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  h1 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    text-align: center;
    color: #666;
    margin-bottom: 2rem;
  }

  .gen-container {
    max-width: 560px;
    margin: 0 auto;
  }

  .gen-btn {
    display: block;
    width: 100%;
    padding: 0.85rem;
    background: #e63946;
    color: white;
    border: none;
    border-radius: 10px;
    font-size: 1.1rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
  }

  .gen-btn:hover {
    background: #d32f3f;
  }

  .gen-btn:active {
    transform: scale(0.98);
  }

  .gen-btn:disabled {
    background: #ccc;
    cursor: not-allowed;
  }

  .loading {
    display: none;
    text-align: center;
    padding: 2rem;
    color: #888;
    font-size: 1rem;
  }

  .error {
    display: none;
    text-align: center;
    padding: 1rem;
    color: #e63946;
    font-weight: 500;
  }

  .result {
    display: none;
    margin-top: 1.5rem;
    background: white;
    border-radius: 12px;
    border: 1px solid #eee;
    padding: 1.5rem;
  }

  .poke-header {
    text-align: center;
    margin-bottom: 0.75rem;
  }

  .poke-header h2 {
    font-size: 1.75rem;
    text-transform: capitalize;
  }

  .category {
    font-size: 0.9rem;
    color: #888;
    font-style: italic;
  }

  .types {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1rem;
  }

  .description {
    font-size: 1rem;
    line-height: 1.6;
    color: #444;
    text-align: center;
    margin-bottom: 1.25rem;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .info-card {
    background: #f9f9f9;
    border-radius: 10px;
    padding: 0.75rem;
    text-align: center;
  }

  .info-card h3 {
    font-size: 0.75rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.2rem;
  }

  .info-card p {
    font-size: 1.15rem;
    font-weight: 700;
  }

  .section {
    margin-bottom: 1.25rem;
  }

  .section h3 {
    font-size: 1rem;
    margin-bottom: 0.5rem;
  }

  .ability-list {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .stats {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .lore-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: #555;
    font-style: italic;
  }
</style>

<script>
  const generateBtn = document.getElementById('generate-btn') as HTMLButtonElement;
  const loadingEl = document.getElementById('loading')!;
  const errorEl = document.getElementById('error')!;
  const resultEl = document.getElementById('result')!;

  const TYPE_COLORS: Record<string, string> = {
    normal: '#a8a77a', fire: '#ee8130', water: '#6390f0', electric: '#f7d02c',
    grass: '#7ac74c', ice: '#96d9d6', fighting: '#c22e28', poison: '#a33ea1',
    ground: '#e2bf65', flying: '#a98ff3', psychic: '#f95587', bug: '#a6b91a',
    rock: '#b6a136', ghost: '#735797', dragon: '#6f35fc', dark: '#705746',
    steel: '#b7b7ce', fairy: '#d685ad',
  };

  const LIGHT_TEXT_TYPES = new Set(['electric', 'ice', 'ground', 'steel']);

  generateBtn.addEventListener('click', async () => {
    generateBtn.disabled = true;
    loadingEl.style.display = 'block';
    errorEl.style.display = 'none';
    resultEl.style.display = 'none';

    try {
      const res = await fetch('/api/generate', { method: 'POST' });
      const data = await res.json();

      if (!res.ok || data.error) {
        throw new Error(data.error || 'Generation failed');
      }

      // Name + category
      document.getElementById('poke-name')!.textContent = data.name;
      document.getElementById('poke-category')!.textContent = data.category || '';

      // Types
      const typesEl = document.getElementById('poke-types')!;
      typesEl.innerHTML = data.types
        .map((t: string) => {
          const color = TYPE_COLORS[t.toLowerCase()] || '#777';
          const textColor = LIGHT_TEXT_TYPES.has(t.toLowerCase()) ? '#333' : 'white';
          return `<span style="background:${color};color:${textColor};padding:0.3rem 0.9rem;border-radius:20px;font-weight:600;font-size:0.85rem;text-transform:capitalize">${t}</span>`;
        })
        .join('');

      // Description
      document.getElementById('poke-desc')!.textContent = data.description;

      // Height + Weight
      document.getElementById('poke-height')!.textContent = `${data.height} m`;
      document.getElementById('poke-weight')!.textContent = `${data.weight} kg`;

      // Abilities
      document.getElementById('poke-abilities')!.innerHTML = data.abilities
        .map((a: string) => `<span style="padding:0.35rem 0.8rem;background:#f0f0f0;border-radius:20px;font-size:0.9rem;text-transform:capitalize">${a}</span>`)
        .join('');

      // Stats
      const statNames: Record<string, string> = {
        hp: 'HP', attack: 'Attack', defense: 'Defense',
        special_attack: 'Sp. Atk', special_defense: 'Sp. Def', speed: 'Speed',
      };
      const statsEl = document.getElementById('poke-stats')!;
      statsEl.innerHTML = Object.entries(data.stats)
        .map(([key, val]) => {
          const pct = Math.min(((val as number) / 255) * 100, 100);
          return `
            <div style="display:grid;grid-template-columns:90px 1fr 40px;align-items:center;gap:0.75rem">
              <span style="font-size:0.85rem;color:#555">${statNames[key] || key}</span>
              <div style="height:10px;background:#eee;border-radius:5px;overflow:hidden">
                <div style="height:100%;width:${pct}%;background:#e63946;border-radius:5px"></div>
              </div>
              <span style="font-weight:700;font-size:0.9rem;text-align:right">${val}</span>
            </div>`;
        })
        .join('');

      // Lore
      document.getElementById('poke-lore')!.textContent = data.lore || '';

      resultEl.style.display = 'block';
    } catch (err: any) {
      errorEl.textContent = err.message || 'Something went wrong. Try again.';
      errorEl.style.display = 'block';
    } finally {
      generateBtn.disabled = false;
      loadingEl.style.display = 'none';
    }
  });
</script>
